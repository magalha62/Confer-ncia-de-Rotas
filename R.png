<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#087c35">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <link rel="icon" type="image/jpeg" href="techmagalhaes.jpg">
  <title>Conferência de Rotas — SPOT e SDD</title>
  <style>
    :root{--bg:#f1f5f2;--panel:#fff;--panel2:#f8fbf9;--line:#d9e4de;--text:#27312d;--muted:#697c73;--green:#087c35;--yellow:#ffd21f;--red:#dc4c4c;--blue:#1684c7;--shadow:0 18px 46px #173c2920}
    *{box-sizing:border-box}body{margin:0;background:radial-gradient(circle at 100% 0,#fff4b8 0,transparent 24%),radial-gradient(circle at 0 10%,#caead8 0,transparent 27%),var(--bg);color:var(--text);font:15px/1.45 Inter,system-ui,-apple-system,Segoe UI,sans-serif;min-height:100vh}
    button,input,select{font:inherit}button{cursor:pointer}.wrap{width:min(1320px,94vw);margin:auto;padding:30px 0 70px}.top{display:flex;justify-content:space-between;gap:20px;align-items:center;margin-bottom:24px;padding:16px 20px;background:#ffffffdf;border:1px solid #fff;border-radius:20px;box-shadow:var(--shadow)}.brand{display:flex;gap:18px;align-items:center}.logo{width:230px;max-width:30vw;height:68px;object-fit:contain;object-position:left}.brandcopy{padding-left:18px;border-left:1px solid var(--line)}.brand h1{font-size:clamp(19px,2.5vw,27px);line-height:1.1;margin:0}.brand p{color:var(--muted);margin:5px 0 0}.pill{padding:8px 12px;border-radius:999px;background:#edf8f1;border:1px solid #cce6d5;color:var(--green);font-weight:700}
    .drop{position:relative;background:linear-gradient(145deg,#fff,#f5faf7);border:1.5px dashed #68a77e;border-radius:22px;padding:42px 24px;text-align:center;transition:.2s;box-shadow:var(--shadow)}.drop:before{content:'';position:absolute;left:0;top:24px;bottom:24px;width:5px;border-radius:0 8px 8px 0;background:linear-gradient(var(--yellow),var(--green))}.drop.drag{border-color:var(--green);transform:translateY(-2px);background:#eef9f2}.drop input{position:absolute;inset:0;width:100%;opacity:0;cursor:pointer}.drop .icon{font-size:40px}.drop h2{margin:7px 0 4px}.drop p{margin:0;color:var(--muted)}
    .toolbar{display:flex;flex-wrap:wrap;align-items:end;gap:12px;margin:20px 0}.field{display:grid;gap:6px}.field label{font-size:12px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.06em}.field input,.field select{color:var(--text);background:var(--panel);border:1px solid var(--line);border-radius:11px;padding:10px 12px;outline:none}.field input:focus,.field select:focus{border-color:var(--green)}.search{min-width:240px;flex:1}.btn{border:0;border-radius:11px;padding:11px 15px;font-weight:750;background:var(--green);color:#092017}.btn.secondary{background:#ffffff0b;color:var(--text);border:1px solid var(--line)}.btn:disabled{opacity:.45;cursor:not-allowed}
    .cards{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:14px}.card{background:linear-gradient(145deg,var(--panel2),var(--panel));border:1px solid var(--line);padding:18px;border-radius:17px;min-width:0}.card span{color:var(--muted);font-size:13px}.card strong{display:block;font-size:clamp(24px,3vw,34px);margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.card.total{border-color:#39d98a88;grid-column:span 2}.card.total strong{color:var(--green);font-size:clamp(25px,3vw,38px);white-space:normal;overflow:visible;text-overflow:clip;line-height:1.15;overflow-wrap:anywhere}.revenuecards{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}.revenue{position:relative;overflow:hidden}.revenue:before{content:'';position:absolute;left:0;top:0;bottom:0;width:5px;background:var(--green)}.revenue:nth-child(2):before{background:var(--yellow)}.revenue:nth-child(3):before{background:var(--blue)}.revenue strong{color:var(--text);font-size:clamp(22px,2.5vw,30px)}.splitrevenue{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:13px}.splitrevenue div{padding:9px 10px;border-radius:10px;background:#f3f7f4;border:1px solid var(--line)}.splitrevenue small{display:block;color:var(--muted);font-size:10px;font-weight:800}.splitrevenue b{display:block;margin-top:2px;font-size:14px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .dashboard{display:grid;grid-template-columns:1.35fr .65fr;gap:14px;margin-bottom:20px}.chart{background:linear-gradient(145deg,var(--panel2),var(--panel));border:1px solid var(--line);border-radius:17px;padding:18px;min-width:0}.chart h3{margin:0}.charttop{display:flex;justify-content:space-between;gap:10px;align-items:start;margin-bottom:18px}.charttop small{color:var(--muted)}.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}.mini{border:1px solid #ffffff0c;background:#ffffff05;border-radius:13px;padding:12px}.mini span{font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted)}.mini b{display:block;font-size:21px;margin-top:3px}.bars{height:225px;display:flex;align-items:end;gap:7px;border-bottom:1px solid var(--line);padding:24px 4px 0}.barwrap{height:100%;flex:1;display:flex;flex-direction:column;justify-content:end;align-items:center;min-width:0}.barvalue{font-size:11px;font-weight:800;color:var(--green);margin-bottom:4px}.bar{width:min(28px,80%);min-height:2px;border-radius:7px 7px 2px 2px;background:linear-gradient(#39d98a,#199b65);position:relative;transition:.25s}.bar:hover{filter:brightness(1.18)}.barlabel{font-size:10px;color:var(--muted);margin-top:7px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%}.donutarea{display:grid;place-items:center;min-height:210px}.donut{width:165px;aspect-ratio:1;border-radius:50%;display:grid;place-items:center;position:relative;background:conic-gradient(var(--green) 0 100%)}.donut:after{content:'';position:absolute;inset:24px;background:var(--panel);border-radius:50%}.donutcenter{position:relative;z-index:1;text-align:center}.donutcenter b{display:block;font-size:27px}.donutcenter small{color:var(--muted)}.legend{display:grid;gap:8px;width:100%;margin-top:8px}.legend div{display:flex;justify-content:space-between;gap:8px;color:var(--muted)}.legend i{display:inline-block;width:9px;height:9px;border-radius:50%;margin-right:7px}.legend b{color:var(--text)}
    .pricebox{background:#0e1917;border:1px solid var(--line);border-radius:17px;margin-bottom:20px;overflow:hidden}.pricehead{display:flex;justify-content:space-between;align-items:center;padding:14px 18px;border-bottom:1px solid var(--line)}.pricehead h3{margin:0}.prices{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;padding:16px}.prices input{width:100%}
    .tablebox{background:var(--panel);border:1px solid var(--line);border-radius:17px;overflow:hidden}.tablehead{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid var(--line);color:var(--muted)}.scroll{overflow:auto;max-height:600px}table{width:100%;border-collapse:collapse;white-space:nowrap}th{position:sticky;top:0;z-index:2;background:#eaf3ed;color:#42564c;font-size:12px;text-align:left;padding:11px;border-bottom:1px solid var(--line)}.colfilters th{top:38px;z-index:2;padding:6px;background:#f8fbf9}.colfilter{width:100%;min-width:78px;border:1px solid #d5e2da;background:#fff;color:var(--text);border-radius:7px;padding:6px 7px;font-size:11px;outline:none}.colfilter:focus{border-color:var(--green);box-shadow:0 0 0 2px #087c3514}td{padding:10px 11px;border-bottom:1px solid #e8efeb}tr:hover td{background:#f4faf6}.tag{font-size:12px;font-weight:800;padding:5px 8px;border-radius:999px}.spot{background:#fff3b5;color:#755f00}.sdd{background:#dcefff;color:#126a9d}.empty{padding:46px 20px;text-align:center;color:var(--muted)}.error{color:var(--red);margin-top:12px;display:none}.hidden{display:none!important}.foot{margin-top:14px;color:var(--muted);font-size:12px;text-align:center}
    .field input,.field select{background:#fff}.btn{background:linear-gradient(135deg,#087c35,#00a348);color:#fff;box-shadow:0 7px 18px #0782392c}.btn.secondary{background:#fff;color:var(--text);box-shadow:none}.card,.chart{box-shadow:0 8px 24px #173c290b}.card.total{background:linear-gradient(145deg,#e6f7ec,#fff);border-color:#78b98e}.mini{border-color:var(--line);background:#f8fbf9}.bar{background:linear-gradient(var(--yellow),var(--green))}.bar:hover:after{background:#27312d;color:#fff}.pricebox{background:#fff;box-shadow:0 8px 24px #173c290b}.pricehead{border-left:5px solid var(--yellow)}
    details.pricebox>summary{list-style:none;cursor:pointer}.configsummary{display:flex;justify-content:space-between;align-items:center;padding:17px 18px;border-left:5px solid var(--yellow);font-weight:800}.configsummary::-webkit-details-marker{display:none}.configsummary span:last-child{color:var(--green);font-size:13px}.configsummary span:last-child:after{content:'▼  Expandir'}details[open] .configsummary span:last-child:after{content:'▲  Recolher'}.supabox{border-left-color:var(--green)!important}.configbody{padding:16px;border-top:1px solid var(--line)}.configgrid{display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:end}.hint{color:var(--muted);font-size:12px;margin:10px 0 0}.spotpricewrap{padding:0 16px 18px;overflow:auto}.spotpricewrap h3{margin:2px 0 10px}.spotprices{min-width:720px;border-collapse:separate;border-spacing:0;border:1px solid var(--line);border-radius:12px;overflow:hidden}.spotprices th{position:static;background:#edf6f0;color:#344b40}.spotprices td{padding:7px;border-bottom:1px solid var(--line)}.spotprices tr:last-child td{border-bottom:0}.spotprices input{width:100%;min-width:110px;border:1px solid #d4e1d8;border-radius:8px;padding:8px;color:var(--text);background:#fff}.historymodal{position:fixed;inset:0;background:#13231c99;z-index:20;display:grid;place-items:center;padding:20px}.modalbox{background:#fff;border-radius:20px;width:min(900px,96vw);max-height:85vh;overflow:auto;box-shadow:0 30px 80px #0005}.modalhead{position:sticky;top:0;background:#fff;display:flex;align-items:center;justify-content:space-between;padding:18px 20px;border-bottom:1px solid var(--line);z-index:2}.modalhead h2{margin:0}.closebtn{border:0;background:#edf3ef;border-radius:10px;width:38px;height:38px;font-size:20px}.historylist{padding:14px;display:grid;gap:10px}.historyitem{display:grid;grid-template-columns:1fr auto;gap:14px;align-items:center;border:1px solid var(--line);border-radius:14px;padding:14px}.historyitem h3{margin:0 0 4px;font-size:16px}.historyitem p{margin:0;color:var(--muted);font-size:13px}.status{position:fixed;right:20px;bottom:20px;z-index:30;background:#27312d;color:#fff;padding:12px 16px;border-radius:12px;box-shadow:var(--shadow)}.devfooter{margin-top:26px;background:#fff;border:1px solid var(--line);border-radius:18px;padding:14px 20px;display:flex;align-items:center;justify-content:center;gap:18px;box-shadow:0 8px 24px #173c290b}.devtext{color:var(--muted);font-size:12px;text-align:right;text-transform:uppercase;letter-spacing:.05em}.devtext b{display:block;color:var(--text);font-size:15px;text-transform:none;letter-spacing:0;margin-top:3px}.techlogo{width:270px;height:70px;overflow:hidden;border-left:1px solid var(--line);padding-left:16px}.techlogo img{width:100%;height:100%;object-fit:cover;object-position:center center}
    .printbrand{display:none}.loginscreen{min-height:100vh;display:grid;place-items:center;padding:22px;background:radial-gradient(circle at 15% 5%,#cdebd8,transparent 32%),radial-gradient(circle at 90% 0,#fff0a8,transparent 25%),#f1f5f2}.loginbox{width:min(430px,94vw);background:#fff;border:1px solid var(--line);border-radius:24px;padding:28px;box-shadow:0 28px 70px #173c2930}.loginlogos{display:grid;place-items:center;margin-bottom:20px}.loginlogos img{width:260px;height:82px;object-fit:contain}.loginbox h1{margin:0;text-align:center;font-size:25px}.loginbox>p{text-align:center;color:var(--muted);margin:7px 0 22px}.loginform{display:grid;gap:14px}.loginform .btn{width:100%;padding:13px}.loginerror{color:var(--red);font-size:13px;text-align:center;min-height:18px}.account{display:flex;align-items:center;gap:10px}.account span{font-size:12px;color:var(--muted);max-width:180px;overflow:hidden;text-overflow:ellipsis}.logout{border:1px solid var(--line);background:#fff;border-radius:9px;padding:7px 10px;color:var(--text)}.tabs{display:flex;gap:8px;margin:0 0 18px;background:#fff;padding:7px;border:1px solid var(--line);border-radius:14px;width:max-content}.tabbtn{border:0;background:transparent;color:var(--muted);padding:10px 18px;border-radius:9px;font-weight:800;cursor:pointer}.tabbtn.active{background:var(--green);color:#fff}.backupgrid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin:18px 0}.backupvalue{color:var(--green)!important}.backupactions{display:flex;gap:10px;flex-wrap:wrap;margin:15px 0}.backupsearch{flex:1;min-width:240px}.yes{color:var(--green);font-weight:800}.no{color:var(--red);font-weight:800}
    @media(max-width:1000px){.cards{grid-template-columns:repeat(3,1fr)}.cards .total{grid-column:span 2}.prices{grid-template-columns:repeat(2,1fr)}.dashboard{grid-template-columns:1fr}.kpis{grid-template-columns:repeat(2,1fr)}.brandcopy{display:none}.logo{max-width:46vw}.revenuecards{grid-template-columns:1fr}}@media(max-width:600px){.wrap{padding-top:14px}.top{align-items:center;padding:12px 14px}.logo{width:190px;max-width:65vw;height:56px}.pill{display:none}.drop{padding:30px 15px}.toolbar{align-items:stretch}.field{width:100%}.search{min-width:0}.toolbar .btn{flex:1}.cards{grid-template-columns:1fr 1fr}.cards .total{grid-column:1/-1}.card{padding:14px}.prices{grid-template-columns:1fr}.pricehead{align-items:flex-start;gap:8px;flex-direction:column}.chart{padding:14px}.kpis{grid-template-columns:1fr 1fr}.bars{gap:3px;height:180px}.barlabel{font-size:8px}.devfooter{flex-direction:column;gap:8px}.devtext{text-align:center}.techlogo{border-left:0;border-top:1px solid var(--line);padding:8px 0 0;width:min(280px,90vw)}}
    @media print{@page{size:A4 landscape;margin:6mm}html,body{width:100%;height:100%;background:#fff!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;overflow:hidden}.wrap{width:100%;padding:0}.top,.drop,.toolbar,.pricebox,.tablebox,.foot,.devfooter,#historyTop,.historymodal,.status{display:none!important}#app{display:block!important;zoom:.72}.printbrand{display:flex!important;align-items:center;justify-content:space-between;border-bottom:3px solid var(--green);padding:0 0 7px;margin-bottom:7px;break-inside:avoid}.printbrand img:first-child{width:200px;height:55px;object-fit:contain}.printbrand .printtech{width:220px;height:55px;object-fit:cover;object-position:center}.printtitle{text-align:center}.printtitle h1{font-size:21px;margin:0}.printtitle p{font-size:11px;color:#607067;margin:3px 0 0}.cards,.revenuecards,.dashboard,.chart{break-inside:avoid;page-break-inside:avoid}.cards{grid-template-columns:repeat(5,1fr);gap:6px;margin-bottom:6px}.card{padding:8px;box-shadow:none}.card.total{grid-column:span 2}.card strong,.card.total strong{font-size:19px}.revenuecards{grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:6px}.revenue strong{font-size:17px}.splitrevenue{margin-top:6px}.splitrevenue div{padding:5px 7px}.dashboard{grid-template-columns:1.35fr .65fr;gap:6px;margin:0}.chart{padding:8px;box-shadow:none}.charttop{margin-bottom:7px}.bars{height:115px;padding-top:12px}.kpis{gap:5px;margin-bottom:6px}.mini{padding:5px}.mini b{font-size:14px}.donut{width:105px}.donutarea{min-height:125px}.legend{gap:3px;margin-top:3px}}
    .backupdash{display:grid;grid-template-columns:1.35fr .65fr;gap:14px;margin-bottom:20px}.backupmetric{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.backupmetric div{background:#f3f8f5;border:1px solid var(--line);border-radius:12px;padding:12px}.backupmetric small{display:block;color:var(--muted)}.backupmetric b{display:block;font-size:20px;margin-top:3px}.backupbars{height:180px}.topPdf{white-space:nowrap}@media(max-width:800px){.backupdash{grid-template-columns:1fr}.backupmetric{grid-template-columns:1fr 1fr}}@media print{.tabs,.backupactions{display:none!important}.unified-print #backupView,.unified-print #backupApp{display:block!important}.unified-print #backupView{break-before:page}.backupdash{break-inside:avoid}.backupbars{height:120px}}
    @media print{body.unified-print{height:auto!important;overflow:visible!important}body.unified-print.print-no-routes #app,body.unified-print.print-no-backups #backupView,body.unified-print.print-no-backups #backupApp{display:none!important}body.unified-print.print-no-routes #backupView{break-before:auto}}
  </style>
</head>
<body>
<section id="loginScreen" class="loginscreen"><div class="loginbox"><div class="loginlogos"><img src="R.png" alt="Coopmetro"></div><h1>Acesso ao Dashboard</h1><p>Entre com seu e-mail e senha cadastrados.</p><form id="loginForm" class="loginform"><div class="field"><label>E-mail</label><input id="loginEmail" type="email" autocomplete="username" required placeholder="seu@email.com"></div><div class="field"><label>Senha</label><input id="loginPassword" type="password" autocomplete="current-password" required placeholder="••••••••"></div><button class="btn" id="loginButton" type="submit">Entrar</button><div class="loginerror" id="loginError"></div></form><footer class="devfooter"><div class="devtext">Desenvolvido por<b>Edinan Magalhães</b></div></footer></div></section>
<main class="wrap hidden" id="appShell">
  <header class="top"><div class="brand"><img class="logo" src="R.png" alt="Coopmetro — Soluções em Logística"><div class="brandcopy"><h1>Conferência de Rotas</h1><p>Rotas, faturamento e backups • <span id="cityName">Aguardando CSV</span> • Versão 4.2</p></div></div><div class="account"><button class="btn secondary topPdf" id="exportAllPdf">PDF completo</button><span id="userEmail"></span><button class="logout" id="logoutButton">Sair</button></div></header>
  <nav class="tabs"><button class="tabbtn active" data-tab="routes">Rotas e faturamento</button><button class="tabbtn" data-tab="backups">Backups e suportes</button></nav>
  <section class="drop routeOnly" id="drop"><input id="file" type="file" accept=".csv,text/csv"><div class="icon">📄</div><h2>Arraste seu CSV ou clique para selecionar</h2><p id="fileLabel">Compatível com o relatório Supplier Delivery Success</p><div class="error" id="error"></div></section>
  <div class="routeOnly" style="display:flex;justify-content:center;margin:14px 0"><button class="btn secondary" id="historyTop">↩ Visualizar histórico salvo</button></div>

  <section id="app" class="hidden routeOnly">
    <div class="printbrand"><img src="R.png" alt="Coopmetro"><div class="printtitle"><h1>Dashboard de Faturamento</h1><p id="printInfo">Relatório operacional</p></div><img class="printtech" src="techmagalhaes.jpg" alt="TechMagalhães"></div>
    <div class="toolbar">
      <div class="field search"><label>Pesquisar</label><input id="search" placeholder="Rota, placa, motorista, veículo..."></div>
      <div class="field"><label>Canal</label><select id="channel"><option value="">Todos</option><option value="SPOT">SPOT</option><option value="SDD">SDD</option><option value="OUTRO">Outros</option></select></div>
      <div class="field"><label>Veículo</label><select id="vehicle"><option value="">Todos</option></select></div>
      <button class="btn secondary" id="clear">Limpar filtros</button><button class="btn secondary" id="history">Visualizar histórico</button><button class="btn secondary" id="exportPdf">Exportar dashboard em PDF</button><button class="btn" id="saveHistory">Salvar no histórico</button><button class="btn" id="export">Baixar CSV</button>
    </div>

    <div class="cards">
      <div class="card"><span>Total de rotas</span><strong id="nTotal">0</strong></div>
      <div class="card"><span>Rotas SPOT</span><strong id="nSpot">0</strong></div>
      <div class="card"><span>Rotas SDD</span><strong id="nSdd">0</strong></div>
      <div class="card total"><span>Valor total a pagar</span><strong id="money">R$ 0,00</strong></div>
    </div>

    <div class="revenuecards">
      <div class="card revenue"><span>Faturamento Passeio</span><strong id="revPasseio">R$ 0,00</strong><div class="splitrevenue"><div><small>SPOT</small><b id="revPasseioSpot">R$ 0,00</b></div><div><small>SDD</small><b id="revPasseioSdd">R$ 0,00</b></div></div></div>
      <div class="card revenue"><span>Faturamento Utilitário</span><strong id="revUtil">R$ 0,00</strong><div class="splitrevenue"><div><small>SPOT</small><b id="revUtilSpot">R$ 0,00</b></div><div><small>SDD</small><b id="revUtilSdd">R$ 0,00</b></div></div></div>
      <div class="card revenue"><span>Faturamento VUC</span><strong id="revVuc">R$ 0,00</strong><div class="splitrevenue"><div><small>SPOT</small><b id="revVucSpot">R$ 0,00</b></div><div><small>SDD</small><b id="revVucSdd">R$ 0,00</b></div></div></div>
    </div>

    <section class="dashboard">
      <article class="chart"><div class="charttop"><div><h3>Visão operacional</h3><small>Indicadores calculados conforme os filtros</small></div><span class="tag spot" id="period">—</span></div>
        <div class="kpis"><div class="mini"><span>DS médio</span><b id="kDs">0%</b></div><div class="mini"><span>Valor-base/KM</span><b id="kBase">R$ 0</b></div><div class="mini"><span>Adic. paradas</span><b id="kStops">R$ 0</b></div><div class="mini"><span>Adic. 20%</span><b id="kHoliday">R$ 0</b></div></div>
        <div class="charttop"><div><h3>Rotas por dia</h3><small>Volume diário do período importado</small></div><small id="kKm">0 km rodados</small></div><div class="bars" id="dailyBars"></div>
      </article>
      <article class="chart"><div class="charttop"><div><h3>Perfil da frota</h3><small>Distribuição por tipo de veículo</small></div></div><div class="donutarea"><div class="donut" id="donut"><div class="donutcenter"><b id="donutTotal">0</b><small>rotas</small></div></div><div class="legend" id="legend"></div></div></article>
    </section>

    <details class="pricebox"><summary class="configsummary"><span>⚙️ Tabela de pagamentos e preços SDD</span><span></span></summary><div class="pricehead"><h3>Preços editáveis</h3><small>SPOT usa a faixa de KM_REAL • SDD usa valor fixo</small></div><div class="prices">
      <div class="field"><label>Utilitário SDD (R$)</label><input class="price" data-key="SDD|UTILITARIO" data-default="370,00" inputmode="decimal"></div>
      <div class="field"><label>VUC SDD (R$)</label><input class="price" data-key="SDD|VUC" data-default="590,00" inputmode="decimal"></div>
      <div class="field"><label>Van SDD (R$)</label><input class="price" data-key="SDD|VAN" data-default="400,00" inputmode="decimal"></div>
      <div class="field"><label>Passeio (R$)</label><input class="price" data-key="ALL|PASSEIO" data-default="224,30" inputmode="decimal"></div>
      <div class="field"><label>SPOT — 1ª a 60ª parada</label><input class="price" data-key="STOP|T1" data-default="0,58" inputmode="decimal"></div>
      <div class="field"><label>SPOT — 61ª a 90ª parada</label><input class="price" data-key="STOP|T2" data-default="1,96" inputmode="decimal"></div>
      <div class="field"><label>SPOT — acima da 90ª</label><input class="price" data-key="STOP|T3" data-default="0,80" inputmode="decimal"></div>
    </div><div class="spotpricewrap"><h3>Preços SPOT por faixa de KM real</h3><table class="spotprices"><thead><tr><th>Faixa</th><th>Passeio</th><th>Utilitário</th><th>Van</th><th>VUC</th></tr></thead><tbody>
      <tr><td><b>1–100 km</b></td><td><input class="price" data-key="SPOT|PASSEIO|0" data-default="224,30" inputmode="decimal"></td><td><input class="price" data-key="SPOT|UTILITARIO|0" data-default="284,10" inputmode="decimal"></td><td><input class="price" data-key="SPOT|VAN|0" data-default="373,00" inputmode="decimal"></td><td><input class="price" data-key="SPOT|VUC|0" data-default="570,00" inputmode="decimal"></td></tr>
      <tr><td><b>101–150 km</b></td><td><input class="price" data-key="SPOT|PASSEIO|1" data-default="256,30" inputmode="decimal"></td><td><input class="price" data-key="SPOT|UTILITARIO|1" data-default="325,40" inputmode="decimal"></td><td><input class="price" data-key="SPOT|VAN|1" data-default="429,00" inputmode="decimal"></td><td><input class="price" data-key="SPOT|VUC|1" data-default="617,00" inputmode="decimal"></td></tr>
      <tr><td><b>151–200 km</b></td><td><input class="price" data-key="SPOT|PASSEIO|2" data-default="293,00" inputmode="decimal"></td><td><input class="price" data-key="SPOT|UTILITARIO|2" data-default="371,20" inputmode="decimal"></td><td><input class="price" data-key="SPOT|VAN|2" data-default="485,00" inputmode="decimal"></td><td><input class="price" data-key="SPOT|VUC|2" data-default="675,00" inputmode="decimal"></td></tr>
      <tr><td><b>201–300 km</b></td><td><input class="price" data-key="SPOT|PASSEIO|3" data-default="329,60" inputmode="decimal"></td><td><input class="price" data-key="SPOT|UTILITARIO|3" data-default="412,50" inputmode="decimal"></td><td><input class="price" data-key="SPOT|VAN|3" data-default="542,00" inputmode="decimal"></td><td><input class="price" data-key="SPOT|VUC|3" data-default="695,00" inputmode="decimal"></td></tr>
      <tr><td><b>301 km ou mais</b></td><td><input class="price" data-key="SPOT|PASSEIO|4" data-default="361,60" inputmode="decimal"></td><td><input class="price" data-key="SPOT|UTILITARIO|4" data-default="458,30" inputmode="decimal"></td><td><input class="price" data-key="SPOT|VAN|4" data-default="598,00" inputmode="decimal"></td><td><input class="price" data-key="SPOT|VUC|4" data-default="748,00" inputmode="decimal"></td></tr>
    </tbody></table></div></details>

    <details class="pricebox" id="supaPanel"><summary class="configsummary supabox"><span>🔒 Conexão com o Supabase</span><span></span></summary><div class="configbody"><div class="configgrid"><div class="field"><label>URL do projeto</label><input id="supaUrl" placeholder="https://seu-projeto.supabase.co"></div><div class="field"><label>Chave pública / Publishable</label><input id="supaKey" type="password" placeholder="sb_publishable_... ou anon key"></div><button class="btn" id="saveSupa">Salvar conexão</button></div><p class="hint">Use somente a chave pública. Nunca coloque a chave service_role nesta página.</p></div></details>
    <details class="pricebox hidden" id="userAdmin"><summary class="configsummary supabox"><span>👥 Cadastro de usuários</span><span></span></summary><div class="configbody"><form id="userForm" class="configgrid"><div class="field"><label>Nome</label><input id="newUserName" required placeholder="Nome completo"></div><div class="field"><label>E-mail</label><input id="newUserEmail" type="email" required placeholder="usuario@email.com"></div><div class="field"><label>Senha provisória</label><input id="newUserPassword" type="password" minlength="8" required placeholder="Mínimo 8 caracteres"></div><div class="field"><label>Perfil</label><select id="newUserRole"><option value="usuario">Usuário</option><option value="coordenador">Coordenador</option></select></div><button class="btn" id="createUserButton" type="submit">Cadastrar usuário</button></form><p class="hint">Esta área aparece somente para usuários com perfil de coordenador.</p></div></details>

    <section class="tablebox"><div class="tablehead"><span id="shown">0 registros</span><span id="filename"></span></div><div class="scroll"><table><thead><tr><th>Data</th><th>Canal</th><th>Veículo</th><th>Rota</th><th>Placa</th><th>KM real</th><th>Faixa</th><th>Paradas</th><th>Valor-base</th><th>Adic. paradas</th><th>Adic. 20%</th><th>Valor total</th></tr><tr class="colfilters"><th><input class="colfilter" data-col="date" placeholder="Filtrar..."></th><th><input class="colfilter" data-col="channel" placeholder="SPOT/SDD"></th><th><input class="colfilter" data-col="vehicle" placeholder="Veículo"></th><th><input class="colfilter" data-col="route" placeholder="Rota"></th><th><input class="colfilter" data-col="plate" placeholder="Placa"></th><th><input class="colfilter" data-col="km" placeholder="KM"></th><th><input class="colfilter" data-col="band" placeholder="Faixa"></th><th><input class="colfilter" data-col="stops" placeholder="Paradas"></th><th><input class="colfilter" data-col="base" placeholder="Valor"></th><th><input class="colfilter" data-col="stopValue" placeholder="Valor"></th><th><input class="colfilter" data-col="holiday" placeholder="Valor"></th><th><input class="colfilter" data-col="total" placeholder="Valor"></th></tr></thead><tbody id="body"></tbody></table></div></section>
  </section>
  <section id="backupView" class="hidden"><section class="drop" id="backupDrop"><input id="backupFile" type="file" accept=".csv,.xlsx,.xls,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel"><div class="icon">🚑</div><h2>Envie a planilha de backups</h2><p id="backupFileLabel">Lê CSV ou Excel com abas Samuel, Felipe e Igor</p><div class="error" id="backupError"></div></section><div id="backupApp" class="hidden">
    <div class="printbrand"><img src="R.png" alt="Coopmetro"><div class="printtitle"><h1>Dashboard de Backups</h1><p id="backupPrintInfo">Relatório de suportes</p></div><img class="printtech" src="techmagalhaes.jpg" alt="TechMagalhães"></div>
    <div class="backupgrid"><div class="card"><span>Total de suportes</span><strong id="bTotal">0</strong></div><div class="card"><span>Autorizados</span><strong id="bAuthorized">0</strong></div><div class="card"><span>Espelhados</span><strong id="bMirrored">0</strong></div><div class="card"><span>Não espelhados</span><strong id="bNotMirrored">0</strong></div><div class="card"><span>Total de pacotes</span><strong id="bPackages">0</strong></div><div class="card total"><span>Valor dos suportes</span><strong class="backupvalue" id="bValue">R$ 0,00</strong></div></div>
    <section class="backupdash"><div class="chart"><div class="charttop"><div><h3>Backups por dia</h3><small>Quantidade visível sem passar o mouse</small></div></div><div class="bars backupbars" id="backupDailyBars"></div></div><div class="chart"><div class="charttop"><div><h3>Resumo por veículo</h3><small>Quantidade e faturamento</small></div></div><div class="backupmetric" id="backupVehicleMetrics"></div></div></section>
    <details class="pricebox"><summary class="configsummary"><span>⚙️ Preço fixo do backup por veículo</span><span></span></summary><div class="prices"><div class="field"><label>Passeio (R$)</label><input class="backupPrice" data-key="PASSEIO" data-default="0,00" inputmode="decimal"></div><div class="field"><label>Utilitário (R$)</label><input class="backupPrice" data-key="UTILITARIO" data-default="0,00" inputmode="decimal"></div><div class="field"><label>VAN (R$)</label><input class="backupPrice" data-key="VAN" data-default="0,00" inputmode="decimal"></div><div class="field"><label>VUC (R$)</label><input class="backupPrice" data-key="VUC" data-default="0,00" inputmode="decimal"></div></div><p class="hint" style="padding:0 16px 16px">Cada suporte autorizado recebe somente o valor fixo do veículo. Pacotes e paradas são indicadores e não alteram o pagamento. Se o veículo não for reconhecido, escolha o tipo na tabela.</p></details>
    <div class="backupactions"><input class="colfilter backupsearch" id="backupSearch" placeholder="Pesquisar data, rota, placa, solicitante ou motivo..."><button class="btn" id="backupExport">Baixar CSV calculado</button></div>
    <section class="tablebox"><div class="tablehead"><span id="backupShown">0 registros</span><span id="backupFilename"></span></div><div class="scroll"><table><thead><tr><th>Data</th><th>SVC</th><th>Rota</th><th>Placa atendida</th><th>Pacotes</th><th>Paradas</th><th>Veículo do backup</th><th>Operação</th><th>Placa backup</th><th>Solicitante</th><th>Autorizado</th><th>Descontar?</th><th>Valor</th></tr></thead><tbody id="backupBody"></tbody></table></div></section>
  </div></section>
  <section id="historyModal" class="historymodal hidden"><div class="modalbox"><div class="modalhead"><div><h2>Histórico de fechamentos</h2><small id="historySource">Salvos neste aparelho</small></div><button class="closebtn" id="closeHistory">×</button></div><div class="historylist" id="historyList"></div></div></section>
  <div id="status" class="status hidden"></div>
  <p class="foot">Nada é enviado para a internet sem sua configuração: o CSV é processado diretamente no navegador.</p>
  <footer class="devfooter"><div class="devtext">Desenvolvido e distribuído por<b>Edinan Magalhães</b></div><div class="techlogo"><img src="techmagalhaes.jpg" alt="TechMagalhães — Soluções e Energia"></div></footer>
</main>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="config.js"></script>
<script>
const $=s=>document.querySelector(s), $$=s=>[...document.querySelectorAll(s)];
let rows=[], filtered=[], sourceName='rotas.csv';
const money=new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL'});
const norm=s=>(s??'').toString().normalize('NFD').replace(/[\u0300-\u036f]/g,'').trim().toUpperCase();
function parseCSV(text){
  text=text.replace(/^\uFEFF/,''); const out=[]; let row=[],cell='',quoted=false;
  for(let i=0;i<text.length;i++){const c=text[i],n=text[i+1];if(c==='"'){if(quoted&&n==='"'){cell+='"';i++}else quoted=!quoted}else if(c===','&&!quoted){row.push(cell);cell=''}else if((c==='\n'||c==='\r')&&!quoted){if(c==='\r'&&n==='\n')i++;row.push(cell);if(row.some(x=>x!==''))out.push(row);row=[];cell=''}else cell+=c}row.push(cell);if(row.some(x=>x!==''))out.push(row);if(out.length<2)return [];
  const headers=out[0].map(x=>x.trim());return out.slice(1).map(r=>Object.fromEntries(headers.map((h,i)=>[h,r[i]??''])));
}
function findKey(obj,wanted){const keys=Object.keys(obj);return keys.find(k=>norm(k)===norm(wanted))||keys.find(k=>norm(k).includes(norm(wanted)))}
function get(r,key){const k=findKey(r,key);return k?r[k]:''}
function detectCity(list){if(!list.length)return'Aguardando CSV';const cityKeys=['Cidade','Município','Municipio','City','Nome da cidade','Unidade'];for(const key of cityKeys){const values=[...new Set(list.map(r=>get(r,key)).filter(Boolean))];if(values.length===1)return values[0];if(values.length>1)return'Várias cidades'}const stationMap={EGO4:'Anápolis'};const xpts=[...new Set(list.map(r=>norm(get(r,'XPT'))).filter(Boolean))];if(xpts.length===1)return stationMap[xpts[0]]||xpts[0];if(xpts.length>1)return'Várias unidades';return'Cidade não informada'}
function updateCity(){const city=detectCity(rows);$('#cityName').textContent=city;document.title=`Conferência de Rotas — ${city}`}
function channelOf(r){const v=norm(get(r,'CANAL'));return v.includes('SPOT')?'SPOT':v.includes('SDD')?'SDD':'OUTRO'}
function vehicleOf(r){const v=norm(get(r,'Veículo'));return v.includes('VAN')?'VAN':v.includes('UTILIT')?'UTILITARIO':v.includes('PASSEIO')?'PASSEIO':v.includes('VUC')?'VUC':'OUTRO'}
function labelVehicle(r){return get(r,'Veículo')||'Não informado'}
function num(v){if(v==null||v==='')return 0;let s=String(v).trim().replace(/R\$|\s/g,'');if(s.includes(',')&&s.includes('.'))s=s.replace(/\./g,'').replace(',','.');else s=s.replace(',','.');return Number(s)||0}
function prices(){return Object.fromEntries($$('.price').map(x=>[x.dataset.key,num(x.value)]))}
const spotRates={PASSEIO:[224.30,256.30,293,329.60,361.60],UTILITARIO:[284.10,325.40,371.20,412.50,458.30],VAN:[373,429,485,542,598],VUC:[570,617,675,695,748]};
function kmBand(r){const km=Math.max(0,num(get(r,'KM_REAL')));return km<=100?0:km<=150?1:km<=200?2:km<=300?3:4}
function kmBandLabel(r){return ['1–100','101–150','151–200','201–300','301+'][kmBand(r)]}
function baseValueOf(r){const c=channelOf(r),v=vehicleOf(r),p=prices();if(c==='SPOT'){const band=kmBand(r),configured=p[`SPOT|${v}|${band}`];return configured??(spotRates[v]||[0,0,0,0,0])[band]}if(c==='SDD'){if(v==='PASSEIO')return p['ALL|PASSEIO']||0;return p[`${c}|${v}`]||0}return 0}
function stopValueOf(r){if(channelOf(r)!=='SPOT')return 0;const stops=Math.max(0,num(get(r,'Parada'))),p=prices();return Math.min(stops,60)*(p['STOP|T1']||0)+Math.min(Math.max(stops-60,0),30)*(p['STOP|T2']||0)+Math.max(stops-90,0)*(p['STOP|T3']||0)}
function easter(y){const a=y%19,b=Math.floor(y/100),c=y%100,d=Math.floor(b/4),e=b%4,f=Math.floor((b+8)/25),g=Math.floor((b-f+1)/3),h=(19*a+b-d-g+15)%30,i=Math.floor(c/4),k=c%4,l=(32+2*e+2*i-h-k)%7,m=Math.floor((a+11*h+22*l)/451),month=Math.floor((h+l-7*m+114)/31),day=(h+l-7*m+114)%31+1;return new Date(y,month-1,day)}
function isSundayOrHoliday(r){const d=parsePtDate(get(r,'Data'));if(isNaN(d))return false;if(d.getDay()===0)return true;const md=`${d.getMonth()+1}-${d.getDate()}`,fixed=new Set(['1-1','4-21','5-1','9-7','10-12','11-2','11-15','11-20','12-25']);return fixed.has(md)}
function holidayValueOf(r){return isSundayOrHoliday(r)?(baseValueOf(r)+stopValueOf(r))*.20:0}
function valueOf(r){return baseValueOf(r)+stopValueOf(r)+holidayValueOf(r)}
const sumKey=(list,key)=>list.reduce((s,r)=>s+num(get(r,key)),0);
function parsePtDate(s){const months={jan:0,fev:1,mar:2,abr:3,mai:4,jun:5,jul:6,ago:7,set:8,out:9,nov:10,dez:11};const m=String(s).match(/(\d{1,2})\s+de\s+([a-zç]+).*?(\d{4})/i);return m?new Date(+m[3],months[norm(m[2]).slice(0,3).toLowerCase()]??0,+m[1]):new Date(s)}
function escapeHtml(v){return String(v??'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]))}
function showError(msg){$('#error').textContent=msg;$('#error').style.display='block'}
function loadFile(file){if(!file)return;if(!/\.csv$/i.test(file.name))return showError('Selecione um arquivo no formato CSV.');const rd=new FileReader();rd.onload=()=>{try{const parsed=parseCSV(rd.result);if(!parsed.length)throw Error('O arquivo está vazio.');if(!findKey(parsed[0],'CANAL')||!findKey(parsed[0],'Veículo'))throw Error('Não encontrei as colunas CANAL e Veículo neste CSV.');rows=parsed;sourceName=file.name;updateCity();$('#error').style.display='none';$('#fileLabel').textContent=`${file.name} • ${rows.length} registros carregados`;$('#filename').textContent=file.name;$('#app').classList.remove('hidden');fillVehicles();apply()}catch(e){showError(e.message)}};rd.onerror=()=>showError('Não foi possível ler o arquivo.');rd.readAsText(file,'UTF-8')}
function fillVehicles(){const vals=[...new Set(rows.map(labelVehicle))].sort((a,b)=>a.localeCompare(b,'pt-BR'));$('#vehicle').innerHTML='<option value="">Todos</option>'+vals.map(v=>`<option>${escapeHtml(v)}</option>`).join('')}
function columnValue(r,col){const map={date:()=>get(r,'Data'),channel:()=>channelOf(r),vehicle:()=>labelVehicle(r),route:()=>get(r,'Rotas'),plate:()=>get(r,'Placa'),km:()=>get(r,'KM_REAL'),band:()=>channelOf(r)==='SPOT'?kmBandLabel(r):'Fixa',stops:()=>get(r,'Parada'),base:()=>money.format(baseValueOf(r)),stopValue:()=>money.format(stopValueOf(r)),holiday:()=>money.format(holidayValueOf(r)),total:()=>money.format(valueOf(r))};return map[col]?map[col]():''}
function apply(){const q=norm($('#search').value),c=$('#channel').value,v=$('#vehicle').value,colFilters=Object.fromEntries($$('.colfilter').map(x=>[x.dataset.col,norm(x.value)]).filter(x=>x[1]));filtered=rows.filter(r=>(!c||channelOf(r)===c)&&(!v||labelVehicle(r)===v)&&(!q||norm(Object.values(r).join(' ')).includes(q))&&Object.entries(colFilters).every(([col,val])=>norm(columnValue(r,col)).includes(val)));render()}
function render(){
  $('#nTotal').textContent=filtered.length.toLocaleString('pt-BR');$('#nSpot').textContent=filtered.filter(r=>channelOf(r)==='SPOT').length.toLocaleString('pt-BR');$('#nSdd').textContent=filtered.filter(r=>channelOf(r)==='SDD').length.toLocaleString('pt-BR');$('#money').textContent=money.format(filtered.reduce((s,r)=>s+valueOf(r),0));$('#shown').textContent=`${filtered.length.toLocaleString('pt-BR')} de ${rows.length.toLocaleString('pt-BR')} registros`;renderRevenueCards();
  renderDashboard();
  $('#body').innerHTML=filtered.length?filtered.map(r=>{const c=channelOf(r);return `<tr><td>${escapeHtml(get(r,'Data'))}</td><td><span class="tag ${c.toLowerCase()}">${c}</span></td><td>${escapeHtml(labelVehicle(r))}</td><td>${escapeHtml(get(r,'Rotas'))}</td><td>${escapeHtml(get(r,'Placa'))}</td><td>${escapeHtml(get(r,'KM_REAL'))}</td><td>${c==='SPOT'?kmBandLabel(r):'Fixa'}</td><td>${escapeHtml(get(r,'Parada'))}</td><td>${money.format(baseValueOf(r))}</td><td>${money.format(stopValueOf(r))}</td><td>${money.format(holidayValueOf(r))}${isSundayOrHoliday(r)?' ☀':''}</td><td><b>${money.format(valueOf(r))}</b></td></tr>`}).join(''):'<tr><td colspan="12" class="empty">Nenhum registro encontrado com esses filtros.</td></tr>';
}
function revenue(type,channel=''){return filtered.filter(r=>vehicleOf(r)===type&&(!channel||channelOf(r)===channel)).reduce((s,r)=>s+valueOf(r),0)}
function renderRevenueCards(){const groups=[['PASSEIO','revPasseio'],['UTILITARIO','revUtil'],['VUC','revVuc']];groups.forEach(([type,id])=>{$('#'+id).textContent=money.format(revenue(type));$('#'+id+'Spot').textContent=money.format(revenue(type,'SPOT'));$('#'+id+'Sdd').textContent=money.format(revenue(type,'SDD'))})}
function renderDashboard(){
  const packages=sumKey(filtered,'Pacotes'),delivered=sumKey(filtered,'Entregue'),fails=sumKey(filtered,'Insucessos'),km=sumKey(filtered,'KM_REAL');let ds=filtered.length?filtered.reduce((s,r)=>s+num(get(r,'DS')),0)/filtered.length:0;if(ds<=1)ds*=100;
  $('#kDs').textContent=ds.toLocaleString('pt-BR',{maximumFractionDigits:2})+'%';$('#kBase').textContent=money.format(filtered.reduce((s,r)=>s+baseValueOf(r),0));$('#kStops').textContent=money.format(filtered.reduce((s,r)=>s+stopValueOf(r),0));$('#kHoliday').textContent=money.format(filtered.reduce((s,r)=>s+holidayValueOf(r),0));$('#kKm').textContent=km.toLocaleString('pt-BR',{maximumFractionDigits:0})+' km rodados';
  const dates=filtered.map(r=>parsePtDate(get(r,'Data'))).filter(d=>!isNaN(d));if(dates.length){const min=new Date(Math.min(...dates)),max=new Date(Math.max(...dates));$('#period').textContent=min.toLocaleDateString('pt-BR',{day:'2-digit',month:'short'})+' — '+max.toLocaleDateString('pt-BR',{day:'2-digit',month:'short'})}else $('#period').textContent='Sem período';
  const daily={};filtered.forEach(r=>{const d=get(r,'Data')||'Sem data';daily[d]=(daily[d]||0)+1});const dayEntries=Object.entries(daily).sort((a,b)=>parsePtDate(a[0])-parsePtDate(b[0]));const maxDay=Math.max(1,...dayEntries.map(x=>x[1]));$('#dailyBars').innerHTML=dayEntries.map(([d,n])=>`<div class="barwrap"><span class="barvalue">${n}</span><div class="bar" style="height:${Math.max(2,n/maxDay*100)}%"></div><span class="barlabel">${escapeHtml(d.replace(/ de [a-zç]+\.?( de)?/i,'/'))}</span></div>`).join('')||'<div class="empty">Sem dados</div>';
  const groups={UTILITARIO:0,PASSEIO:0,VUC:0,VAN:0,OUTRO:0};filtered.forEach(r=>groups[vehicleOf(r)]++);const colors={UTILITARIO:'#39d98a',PASSEIO:'#ffe36e',VUC:'#61b6ff',VAN:'#ff8ac5',OUTRO:'#a785ff'},labels={UTILITARIO:'Utilitários',PASSEIO:'Passeio',VUC:'VUC',VAN:'Van',OUTRO:'Outros'},total=filtered.length;let deg=0,parts=[];Object.entries(groups).forEach(([k,n])=>{if(!n)return;const end=deg+(n/Math.max(1,total))*360;parts.push(`${colors[k]} ${deg}deg ${end}deg`);deg=end});$('#donut').style.background=parts.length?`conic-gradient(${parts.join(',')})`:'#294139';$('#donutTotal').textContent=total.toLocaleString('pt-BR');$('#legend').innerHTML=Object.entries(groups).filter(x=>x[1]).map(([k,n])=>`<div><span><i style="background:${colors[k]}"></i>${labels[k]}</span><b>${n} · ${(n/total*100).toLocaleString('pt-BR',{maximumFractionDigits:1})}%</b></div>`).join('')||'<div>Sem dados</div>';
}
function csvCell(v){v=String(v??'');return /[",\n]/.test(v)?`"${v.replace(/"/g,'""')}"`:v}
function exportCSV(){const headers=['Data','Canal','Tipo de Veículo','Veículo','Rota','Placa','Driver','KM Real','Faixa KM','Paradas','Valor Base','Adicional Paradas','Adicional Domingo/Feriado','Valor Total'];const data=filtered.map(r=>[get(r,'Data'),channelOf(r),vehicleOf(r),labelVehicle(r),get(r,'Rotas'),get(r,'Placa'),get(r,'Driver'),get(r,'KM_REAL'),channelOf(r)==='SPOT'?kmBandLabel(r):'Fixa',get(r,'Parada'),baseValueOf(r).toFixed(2).replace('.',','),stopValueOf(r).toFixed(2).replace('.',','),holidayValueOf(r).toFixed(2).replace('.',','),valueOf(r).toFixed(2).replace('.',',')]);const blob=new Blob(['\uFEFF'+[headers,...data].map(r=>r.map(csvCell).join(';')).join('\r\n')],{type:'text/csv;charset=utf-8'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=sourceName.replace(/\.csv$/i,'')+'-formatado.csv';a.click();setTimeout(()=>URL.revokeObjectURL(a.href),1000)}
function exportDashboardPdf(){if(!rows.length)return toast('Envie um CSV antes de gerar o PDF.');const city=detectCity(rows),now=new Date().toLocaleString('pt-BR');$('#printInfo').textContent=`${city} • ${filtered.length} rotas exibidas • Gerado em ${now}`;const oldTitle=document.title;document.title=`Dashboard-${city}-${new Date().toISOString().slice(0,10)}`;window.print();setTimeout(()=>document.title=oldTitle,1000)}
function toast(msg){const el=$('#status');el.textContent=msg;el.classList.remove('hidden');clearTimeout(toast.timer);toast.timer=setTimeout(()=>el.classList.add('hidden'),3500)}
function openHistoryDB(){return new Promise((resolve,reject)=>{const req=indexedDB.open('coopmetro_faturamento',1);req.onupgradeneeded=()=>req.result.createObjectStore('historicos',{keyPath:'id'});req.onsuccess=()=>resolve(req.result);req.onerror=()=>reject(req.error)})}
async function localPut(item){const db=await openHistoryDB();return new Promise((resolve,reject)=>{const tx=db.transaction('historicos','readwrite');tx.objectStore('historicos').put(item);tx.oncomplete=resolve;tx.onerror=()=>reject(tx.error)})}
async function localGetAll(){const db=await openHistoryDB();return new Promise((resolve,reject)=>{const req=db.transaction('historicos').objectStore('historicos').getAll();req.onsuccess=()=>resolve(req.result.filter(x=>!x.user_id||x.user_id===authSession?.user?.id).sort((a,b)=>new Date(b.created_at)-new Date(a.created_at)));req.onerror=()=>reject(req.error)})}
let hostedSupa={url:'',key:''};
async function loadHostedConfig(){const fromFile=window.APP_CONFIG||{};if(fromFile.supabaseUrl&&fromFile.supabasePublishableKey)hostedSupa={url:fromFile.supabaseUrl,key:fromFile.supabasePublishableKey};try{const res=await fetch('/.netlify/functions/supabase-config',{cache:'no-store'});if(res.ok){const data=await res.json();if(data.url&&data.key)hostedSupa={url:data.url,key:data.key}}}catch(e){}if(hostedSupa.url&&hostedSupa.key){$('#supaUrl').value=hostedSupa.url;$('#supaKey').value=hostedSupa.key;toast('Supabase configurado pelo Netlify.')}}
const configReady=loadHostedConfig();
let authSession=null;
function authApiHeaders(){const {key}=supaConfig();return{'apikey':key,'Content-Type':'application/json'}}
function storeSession(session){authSession=session;localStorage.setItem('coopmetro-auth-session',JSON.stringify(session))}
async function loadUserRole(){const {url}=supaConfig();if(!url||!authSession?.user?.id)return'usuario';try{const res=await fetch(`${url.replace(/\/$/,'')}/rest/v1/profiles?select=role&id=eq.${encodeURIComponent(authSession.user.id)}&limit=1`,{headers:supaHeaders()});if(!res.ok)return'usuario';const data=await res.json();return data[0]?.role||'usuario'}catch(e){return'usuario'}}
async function showAuthenticated(){if(!authSession?.access_token)return;$('#loginScreen').classList.add('hidden');$('#appShell').classList.remove('hidden');$('#userEmail').textContent=authSession.user?.email||'Usuário conectado';const role=await loadUserRole();if(role==='coordenador')$('#userAdmin').classList.remove('hidden');else $('#userAdmin').classList.add('hidden')}
function showLogin(message=''){authSession=null;localStorage.removeItem('coopmetro-auth-session');$('#appShell').classList.add('hidden');$('#loginScreen').classList.remove('hidden');$('#loginError').textContent=message}
async function refreshAuth(session){const {url,key}=supaConfig();if(!url||!key||!session?.refresh_token)return false;const res=await fetch(`${url.replace(/\/$/,'')}/auth/v1/token?grant_type=refresh_token`,{method:'POST',headers:authApiHeaders(),body:JSON.stringify({refresh_token:session.refresh_token})});if(!res.ok)return false;const data=await res.json();data.expires_at=Math.floor(Date.now()/1000)+(data.expires_in||3600);storeSession(data);return true}
async function initAuth(){await configReady;const {url,key}=supaConfig();if(!url||!key)return showLogin('Configure o Supabase no Netlify antes de entrar.');let saved=null;try{saved=JSON.parse(localStorage.getItem('coopmetro-auth-session')||'null')}catch(e){}if(saved?.access_token){if((saved.expires_at||0)>Math.floor(Date.now()/1000)+60){authSession=saved;return showAuthenticated()}if(await refreshAuth(saved))return showAuthenticated()}showLogin()}
async function loginWithPassword(email,password){await configReady;const {url,key}=supaConfig();if(!url||!key)throw Error('Supabase ainda não está configurado.');const res=await fetch(`${url.replace(/\/$/,'')}/auth/v1/token?grant_type=password`,{method:'POST',headers:authApiHeaders(),body:JSON.stringify({email,password})});const data=await res.json();if(!res.ok)throw Error(data.error_description||data.msg||'E-mail ou senha inválidos.');data.expires_at=Math.floor(Date.now()/1000)+(data.expires_in||3600);storeSession(data);await showAuthenticated()}
async function logout(){const {url}=supaConfig();try{if(url&&authSession?.access_token)await fetch(`${url.replace(/\/$/,'')}/auth/v1/logout`,{method:'POST',headers:{...authApiHeaders(),Authorization:`Bearer ${authSession.access_token}`}})}catch(e){}showLogin('Sessão encerrada.')}
function supaConfig(){return{url:hostedSupa.url||localStorage.getItem('coopmetro-supa-url')||'',key:hostedSupa.key||localStorage.getItem('coopmetro-supa-key')||''}}
function supaHeaders(){const {key}=supaConfig(),headers={'apikey':key,'Content-Type':'application/json'};if(authSession?.access_token)headers.Authorization=`Bearer ${authSession.access_token}`;else if(!key.startsWith('sb_publishable_'))headers.Authorization=`Bearer ${key}`;return headers}
async function supaSave(item){await configReady;const {url,key}=supaConfig();if(!url||!key)return false;const payload={id:item.id,created_at:item.created_at,nome_arquivo:item.filename,total:item.total,total_rotas:item.total_rotas,dados:item.data};const res=await fetch(`${url.replace(/\/$/,'')}/rest/v1/historico_faturamento`,{method:'POST',headers:{...supaHeaders(),'Prefer':'return=minimal'},body:JSON.stringify(payload)});if(!res.ok)throw Error((await res.text())||`Erro ${res.status}`);return true}
async function supaGetAll(){await configReady;const {url,key}=supaConfig();if(!url||!key)return[];const res=await fetch(`${url.replace(/\/$/,'')}/rest/v1/historico_faturamento?select=*&order=created_at.desc`,{headers:supaHeaders()});if(!res.ok)throw Error((await res.text())||`Erro ${res.status}`);return(await res.json()).map(x=>({id:x.id,created_at:x.created_at,filename:x.nome_arquivo,total:Number(x.total),total_rotas:x.total_rotas,data:x.dados,source:'Supabase'}))}
async function saveCurrentHistory(){if(!rows.length)return toast('Envie um CSV antes de salvar.');const item={id:crypto.randomUUID(),user_id:authSession?.user?.id||null,created_at:new Date().toISOString(),filename:sourceName,total:rows.reduce((s,r)=>s+valueOf(r),0),total_rotas:rows.length,data:{rows,prices:Object.fromEntries($$('.price').map(x=>[x.dataset.key,x.value]))},source:'Este aparelho'};try{await localPut(item);const cloud=await supaSave(item);toast(cloud?'Histórico salvo no aparelho e no Supabase.':'Histórico salvo neste aparelho.')}catch(e){toast('Salvo no aparelho, mas o Supabase retornou erro.');console.error(e)}}
function historyCard(item){const date=new Date(item.created_at).toLocaleString('pt-BR');return `<article class="historyitem"><div><h3>${escapeHtml(item.filename||'Fechamento sem nome')}</h3><p>${date} • ${item.total_rotas||0} rotas • ${money.format(item.total||0)} • ${escapeHtml(item.source||'Este aparelho')}</p></div><button class="btn openSnapshot" data-id="${escapeHtml(item.id)}" data-source="${escapeHtml(item.source||'Este aparelho')}">Abrir</button></article>`}
let currentHistory=[];
async function showHistory(){const modal=$('#historyModal');modal.classList.remove('hidden');$('#historyList').innerHTML='<div class="empty">Carregando histórico...</div>';try{const local=await localGetAll();let remote=[];try{remote=await supaGetAll()}catch(e){toast('Não foi possível consultar o Supabase. Mostrando histórico local.')}const map=new Map();[...remote,...local].forEach(x=>map.set(x.id,x));currentHistory=[...map.values()].sort((a,b)=>new Date(b.created_at)-new Date(a.created_at));$('#historySource').textContent=supaConfig().url?'Histórico local + Supabase':'Histórico salvo neste aparelho';$('#historyList').innerHTML=currentHistory.length?currentHistory.map(historyCard).join(''):'<div class="empty">Nenhum fechamento salvo ainda.</div>';$$('.openSnapshot').forEach(b=>b.addEventListener('click',()=>openSnapshot(b.dataset.id)))}catch(e){$('#historyList').innerHTML='<div class="empty">Não foi possível abrir o histórico.</div>'}}
function openSnapshot(id){const item=currentHistory.find(x=>x.id===id);if(!item?.data?.rows)return toast('Este histórico não contém dados para restaurar.');rows=item.data.rows;sourceName=item.filename||'historico.csv';updateCity();if(item.data.prices)$$('.price').forEach(x=>{if(item.data.prices[x.dataset.key]!=null){x.value=item.data.prices[x.dataset.key];localStorage.setItem('rota-price-'+x.dataset.key,x.value)}});$('#fileLabel').textContent=`Histórico restaurado • ${sourceName} • ${rows.length} registros`;$('#filename').textContent=sourceName;$('#app').classList.remove('hidden');fillVehicles();apply();$('#historyModal').classList.add('hidden');window.scrollTo({top:$('#app').offsetTop-20,behavior:'smooth'});toast('Fechamento restaurado na dashboard.')}
let backupRows=[],backupFiltered=[],backupSource='backups.csv';
function bget(r,keys){for(const key of keys){const value=get(r,key);if(value!=='')return value}return ''}
function backupPrices(){return Object.fromEntries($$('.backupPrice').map(x=>[x.dataset.key,num(x.value)]))}
function backupDate(r){return bget(r,['DATA DO BACKUP','DATA','DIA'])}
function backupSvc(r){return bget(r,['SVC','XPT','BASE'])}
function backupRoute(r){return bget(r,['ROTA QUE NECESSITA','ROTA NECESSITA','ROTA','ROUTE'])}
function backupTargetPlate(r){return bget(r,['PLACA QUE NECESSITA DO BACKUP','PLACA NECESSITA','PLACA ATENDIDA','PLACA'])}
function backupRequester(r){return bget(r,['QUEM FEZ A SOLICITAÇÃO?','SOLICITANTE','QUEM SOLICITOU'])}
function backupDiscount(r){return bget(r,['DESCONTAR DE COOPERADO ?','DESCONTAR','DESCONTO'])}
function backupAuthorized(r){return norm(bget(r,['AUT','AUTORIZADO','AUTORIZACAO'])).startsWith('SIM')}
function backupMirrored(r){return norm(bget(r,['ROTA QUE REALIZOU O BACKUP OU SE FOI ESPELHADA?','ROTA QUE REALIZOU O BACKUP','ESPELHADA','OPERACAO'])).includes('ESPELHADA')}
function backupPackages(r){return num(bget(r,['QTD PACOTES DO BACKUP','PACOTES','QTD PACOTES','QUANTIDADE PACOTES']))}
function backupStops(r){return num(bget(r,['QTD PARADAS DO BACKUP','PARADAS','QTD PARADAS','QUANTIDADE PARADAS']))}
function backupPlate(r){return norm(bget(r,['PLACA QUE REALIZOU O BACKUP','PLACA BACKUP','PLACA DO BACKUP','PLACA SUPORTE']))}
function backupVehicle(r){const plate=backupPlate(r),saved=localStorage.getItem('backup-vehicle-'+plate);if(saved)return saved;const route=rows.find(x=>norm(get(x,'Placa'))===plate||norm(get(x,'PLACA'))===plate);return route?vehicleOf(route):'OUTRO'}
function backupVehicleSelect(r){const current=backupVehicle(r),plate=backupPlate(r),types=['OUTRO','PASSEIO','UTILITARIO','VAN','VUC'];return `<select class="backupVehicle" data-plate="${escapeHtml(plate)}">${types.map(v=>`<option value="${v}" ${v===current?'selected':''}>${v==='OUTRO'?'Não identificado':v==='UTILITARIO'?'Utilitário':v}</option>`).join('')}</select>`}
function backupValue(r){if(!backupAuthorized(r))return 0;return backupPrices()[backupVehicle(r)]||0}
function parseBackupWorkbook(buffer){if(!window.XLSX)throw Error('Não foi possível carregar o leitor de Excel. Tente enviar CSV ou recarregue a página.');const wb=XLSX.read(buffer,{type:'array'}),wanted=['SAMUEL','FELIPE','IGOR'];let rows=[];wb.SheetNames.forEach(name=>{if(wanted.some(w=>norm(name).includes(w))||wb.SheetNames.length===1){const data=XLSX.utils.sheet_to_json(wb.Sheets[name],{defval:'',raw:false});rows=rows.concat(data.filter(r=>Object.values(r).some(v=>String(v).trim())))} });return rows}
function acceptBackupRows(parsed,file){if(!parsed.length||(!findKey(parsed[0],'DATA DO BACKUP')&&!findKey(parsed[0],'DATA')))throw Error('Não reconheci a planilha de backups.');backupRows=parsed;backupSource=file.name;$('#backupError').style.display='none';$('#backupFileLabel').textContent=`${file.name} • ${backupRows.length} registros carregados`;$('#backupFilename').textContent=file.name;$('#backupPrintInfo').textContent=`${file.name} • ${backupRows.length} registros`;$('#backupApp').classList.remove('hidden');renderBackups()}
function loadBackupFile(file){if(!file)return;const excel=/\.(xlsx|xls)$/i.test(file.name),csv=/\.csv$/i.test(file.name);if(!excel&&!csv)return $('#backupError').textContent='Selecione um CSV ou Excel.';const rd=new FileReader();rd.onload=()=>{try{acceptBackupRows(excel?parseBackupWorkbook(rd.result):parseCSV(rd.result),file)}catch(e){$('#backupError').textContent=e.message;$('#backupError').style.display='block'}};excel?rd.readAsArrayBuffer(file):rd.readAsText(file,'UTF-8')}
function renderBackups(){const q=norm($('#backupSearch').value);backupFiltered=backupRows.filter(r=>!q||norm(Object.values(r).join(' ')).includes(q));const mirrored=backupFiltered.filter(backupMirrored).length;$('#bTotal').textContent=backupFiltered.length.toLocaleString('pt-BR');$('#bAuthorized').textContent=backupFiltered.filter(backupAuthorized).length.toLocaleString('pt-BR');$('#bMirrored').textContent=mirrored.toLocaleString('pt-BR');$('#bNotMirrored').textContent=(backupFiltered.length-mirrored).toLocaleString('pt-BR');$('#bPackages').textContent=backupFiltered.reduce((s,r)=>s+backupPackages(r),0).toLocaleString('pt-BR');$('#bValue').textContent=money.format(backupFiltered.reduce((s,r)=>s+backupValue(r),0));renderBackupDashboard();$('#backupShown').textContent=`${backupFiltered.length} de ${backupRows.length} registros`;$('#backupBody').innerHTML=backupFiltered.length?backupFiltered.map(r=>`<tr><td>${escapeHtml(backupDate(r))}</td><td>${escapeHtml(backupSvc(r))}</td><td>${escapeHtml(backupRoute(r))}</td><td>${escapeHtml(backupTargetPlate(r))}</td><td>${backupPackages(r)}</td><td>${backupStops(r)}</td><td>${backupVehicleSelect(r)}</td><td>${backupMirrored(r)?'Espelhada':'Não espelhada'}</td><td>${escapeHtml(backupPlate(r))}</td><td>${escapeHtml(backupRequester(r))}</td><td class="${backupAuthorized(r)?'yes':'no'}">${backupAuthorized(r)?'Sim':'Não'}</td><td>${escapeHtml(backupDiscount(r))}</td><td><b>${money.format(backupValue(r))}</b></td></tr>`).join(''):'<tr><td colspan="13" class="empty">Nenhum backup encontrado.</td></tr>';$$('.backupVehicle').forEach(x=>x.addEventListener('change',()=>{localStorage.setItem('backup-vehicle-'+x.dataset.plate,x.value);renderBackups()}))}
function renderBackupDashboard(){const days={};backupFiltered.forEach(r=>{const d=backupDate(r)||'Sem data';days[d]=(days[d]||0)+1});const entries=Object.entries(days),max=Math.max(1,...entries.map(x=>x[1]));$('#backupDailyBars').innerHTML=entries.map(([d,n])=>`<div class="barwrap"><span class="barvalue">${n}</span><div class="bar" style="height:${Math.max(4,n/max*100)}%"></div><span class="barlabel">${escapeHtml(d.slice(0,5))}</span></div>`).join('');const types=['PASSEIO','UTILITARIO','VAN','VUC','OUTRO'];$('#backupVehicleMetrics').innerHTML=types.map(t=>{const list=backupFiltered.filter(r=>backupVehicle(r)===t),value=list.reduce((s,r)=>s+backupValue(r),0);return `<div><small>${t==='UTILITARIO'?'Utilitário':t==='OUTRO'?'Não identificado':t}</small><b>${list.length}</b><small>${money.format(value)}</small></div>`}).join('')}
function exportBackupCSV(){const h=['Data','SVC','Rota atendida','Placa atendida','Pacotes','Paradas','Veículo','Operação','Placa backup','Solicitante','Autorizado','Descontar','Valor'];const data=backupFiltered.map(r=>[backupDate(r),backupSvc(r),backupRoute(r),backupTargetPlate(r),backupPackages(r),backupStops(r),backupVehicle(r),backupMirrored(r)?'Espelhada':'Não espelhada',backupPlate(r),backupRequester(r),backupAuthorized(r)?'Sim':'Não',backupDiscount(r),backupValue(r).toFixed(2).replace('.',',')]);const blob=new Blob(['\uFEFF'+[h,...data].map(r=>r.map(csvCell).join(';')).join('\r\n')],{type:'text/csv;charset=utf-8'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=backupSource.replace(/\.(csv|xlsx|xls)$/i,'')+'-calculado.csv';a.click();setTimeout(()=>URL.revokeObjectURL(a.href),1000)}
function exportAllPdf(){if(!rows.length&&!backupRows.length)return toast('Envie ao menos uma planilha antes de exportar.');document.body.classList.toggle('print-no-routes',!rows.length);document.body.classList.toggle('print-no-backups',!backupRows.length);document.body.classList.add('unified-print');const els=[$('#app'),$('#backupView'),$('#backupApp')],states=els.map(x=>x.classList.contains('hidden'));if(rows.length)$('#app').classList.remove('hidden');if(backupRows.length){$('#backupView').classList.remove('hidden');$('#backupApp').classList.remove('hidden')}setTimeout(()=>{window.print();setTimeout(()=>{document.body.classList.remove('unified-print','print-no-routes','print-no-backups');els.forEach((x,i)=>x.classList.toggle('hidden',states[i]))},300)},150)}
function switchTab(tab){$$('.tabbtn').forEach(b=>b.classList.toggle('active',b.dataset.tab===tab));$$('.routeOnly').forEach(x=>x.classList.toggle('hidden',tab!=='routes'||(x.id==='app'&&!rows.length)));$('#backupView').classList.toggle('hidden',tab!=='backups')}
$('#file').addEventListener('change',e=>loadFile(e.target.files[0]));['dragenter','dragover'].forEach(x=>$('#drop').addEventListener(x,e=>{e.preventDefault();$('#drop').classList.add('drag')}));['dragleave','drop'].forEach(x=>$('#drop').addEventListener(x,e=>{e.preventDefault();$('#drop').classList.remove('drag')}));$('#drop').addEventListener('drop',e=>loadFile(e.dataTransfer.files[0]));$('#search').addEventListener('input',apply);$('#channel').addEventListener('change',apply);$('#vehicle').addEventListener('change',apply);$$('.colfilter').forEach(x=>x.addEventListener('input',apply));$('#clear').addEventListener('click',()=>{$('#search').value='';$('#channel').value='';$('#vehicle').value='';$$('.colfilter').forEach(x=>x.value='');apply()});$('#export').addEventListener('click',exportCSV);$('#exportPdf').addEventListener('click',exportDashboardPdf);
$$('.tabbtn').forEach(b=>b.addEventListener('click',()=>switchTab(b.dataset.tab)));$('#backupFile').addEventListener('change',e=>loadBackupFile(e.target.files[0]));$('#backupSearch').addEventListener('input',renderBackups);$('#backupExport').addEventListener('click',exportBackupCSV);$$('.backupPrice').forEach(x=>{x.value=localStorage.getItem('backup-price-'+x.dataset.key)||x.dataset.default;x.addEventListener('input',()=>{localStorage.setItem('backup-price-'+x.dataset.key,x.value);if(backupRows.length)renderBackups()})});['dragenter','dragover'].forEach(x=>$('#backupDrop').addEventListener(x,e=>{e.preventDefault();$('#backupDrop').classList.add('drag')}));['dragleave','drop'].forEach(x=>$('#backupDrop').addEventListener(x,e=>{e.preventDefault();$('#backupDrop').classList.remove('drag')}));$('#backupDrop').addEventListener('drop',e=>loadBackupFile(e.dataTransfer.files[0]));
$('#saveHistory').addEventListener('click',saveCurrentHistory);$('#history').addEventListener('click',showHistory);$('#historyTop').addEventListener('click',showHistory);$('#closeHistory').addEventListener('click',()=>$('#historyModal').classList.add('hidden'));$('#historyModal').addEventListener('click',e=>{if(e.target===$('#historyModal'))$('#historyModal').classList.add('hidden')});$('#supaUrl').value=localStorage.getItem('coopmetro-supa-url')||'';$('#supaKey').value=localStorage.getItem('coopmetro-supa-key')||'';$('#saveSupa').addEventListener('click',()=>{const url=$('#supaUrl').value.trim().replace(/\/$/,'');const key=$('#supaKey').value.trim();if(!url||!key)return toast('Preencha a URL e a chave pública.');localStorage.setItem('coopmetro-supa-url',url);localStorage.setItem('coopmetro-supa-key',key);toast('Conexão salva neste navegador.')});
$('#supaPanel').querySelector('summary').addEventListener('click',e=>{const panel=$('#supaPanel');if(panel.open||sessionStorage.getItem('coopmetro-supa-authorized')==='1')return;e.preventDefault();const password=prompt('Digite a senha para acessar a conexão com o Supabase:');if(password==='Edinan123!'){sessionStorage.setItem('coopmetro-supa-authorized','1');panel.open=true;toast('Acesso autorizado durante esta sessão.')}else if(password!==null)toast('Senha incorreta.')});
$('#loginForm').addEventListener('submit',async e=>{e.preventDefault();const btn=$('#loginButton');btn.disabled=true;$('#loginError').textContent='Entrando...';try{await loginWithPassword($('#loginEmail').value.trim(),$('#loginPassword').value);$('#loginError').textContent=''}catch(err){$('#loginError').textContent=err.message}finally{btn.disabled=false}});$('#logoutButton').addEventListener('click',logout);
$('#userForm').addEventListener('submit',async e=>{e.preventDefault();const btn=$('#createUserButton');btn.disabled=true;try{const res=await fetch('/.netlify/functions/create-user',{method:'POST',headers:{'Content-Type':'application/json',Authorization:`Bearer ${authSession?.access_token||''}`},body:JSON.stringify({name:$('#newUserName').value.trim(),email:$('#newUserEmail').value.trim(),password:$('#newUserPassword').value,role:$('#newUserRole').value})});const data=await res.json();if(!res.ok)throw Error(data.error||'Não foi possível cadastrar.');e.target.reset();toast('Usuário cadastrado com sucesso.')}catch(err){toast(err.message)}finally{btn.disabled=false}});initAuth();
$$('.price').forEach(x=>{x.value=localStorage.getItem('rota-price-'+x.dataset.key)||x.dataset.default||'';x.addEventListener('input',()=>{localStorage.setItem('rota-price-'+x.dataset.key,x.value);if(rows.length)render()})});
$('#exportAllPdf').addEventListener('click',exportAllPdf);
</script>
</body>
</html>
